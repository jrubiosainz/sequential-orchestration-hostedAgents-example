# Copy this file to `.env` and fill in your values.
# `.env` is git-ignored and is NOT baked into the container image; the AI
# Toolkit / Foundry extension resolves the ${VAR} references in agent.yaml from
# this file at deploy time.

# Your Foundry project endpoint, e.g.
# https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT=<your-foundry-project-endpoint>

# A model deployment in that project. Use gpt-5 (a Responses-API model): the
# Researcher uses the Bing Grounding tool, which is only available through the
# Responses API, and gpt-5 supports it. A reasoning model can stay silent for
# ~45-50s while it runs the Bing search; the orchestrator streams a small
# whitespace "heartbeat" every few seconds during that gap so the Foundry
# Playground's live connection never times out ("network error").
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5

# Full ARM id of your "Grounding with Bing Search" connection so the Researcher
# can search the web. Foundry portal -> your project -> Management center ->
# Connected resources -> your Bing connection. It looks like:
# /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<account>/projects/<project>/connections/<connection-name>
# If you leave this empty the agent still runs, but the Researcher answers from
# the model's training data only (no live web search).
BING_GROUNDING_CONNECTION_ID=<your-bing-grounding-connection-id>
