# Copy this file to `.env` and fill in your values.
# `.env` is git-ignored and is NOT baked into the container image.
AZURE_AI_PROJECT_ENDPOINT=<your-foundry-project-endpoint>

# IMPORTANT: use a FAST, non-reasoning chat model here (e.g. gpt-4.1-mini,
# gpt-4o-mini or gpt-4o). The workflow runs three agents in sequence, and the
# Foundry Playground streams the result over a live connection. A slow
# *reasoning* model (e.g. gpt-5) can spend ~45s per call "thinking" before it
# emits any tokens; across three sequential agents that silence makes the
# Playground connection time out with a "network error". A fast model keeps
# the whole run to a few seconds.
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
